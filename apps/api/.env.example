# API bind settings
CROWD_API_HOST=127.0.0.1
CROWD_API_PORT=8000

# Serial settings
CROWD_SERIAL_PORT=COM3
CROWD_BAUD_RATE=115200

# Threshold settings
CROWD_DISTANCE_PASS_THRESHOLD=300
CROWD_ACCEL_DELTA_THRESHOLD=80
CROWD_PHOTO_DELTA_THRESHOLD=100
CROWD_LIGHT_DELTA_THRESHOLD=120
CROWD_PYRO_THRESHOLD=600
CROWD_EI_DIRECTION_AUTO_DETECT=true

# Counts and capacity
CROWD_INITIAL_COUNT_K=0
CROWD_INITIAL_COUNT_E=0
CROWD_INITIAL_COUNT_I=0
CROWD_INITIAL_COUNT_O=10
CROWD_CAPACITY_K=1

# Logs
CROWD_SENSOR_LOG_FILE=data/logs/sensor_log.csv
CROWD_EVENT_LOG_FILE=data/logs/event_log.csv
